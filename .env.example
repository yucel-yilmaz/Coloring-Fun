# Browser-safe Supabase settings
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_GOOGLE_AUTH_ENABLED="false"
VITE_LOCAL_AI_ENABLED="true"

# Public site URL used for SEO tags (canonical, OG, sitemap, robots.txt). Required at build time.
VITE_SITE_URL="http://localhost:3000"
# Self-hosted Plausible analytics. Leave both empty to disable analytics entirely.
VITE_PLAUSIBLE_DOMAIN=""
VITE_PLAUSIBLE_SCRIPT_URL=""

# Application server
PORT="3000"

# Backend-only Supabase settings
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLIC_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."

# 32-byte key encoded as 64 hexadecimal characters. Keep in Secret Manager.
AI_KEYS_MASTER_KEY=""

# Platform-owned moderation key (Gemini API key). User generation keys are stored per account.
GEMINI_MODERATION_API_KEY=""
# Development-only fallback when the platform moderation service is unavailable.
# Never enable this in production.
ALLOW_DEGRADED_MODERATION=false
LOCAL_AI_ENABLED=true
LOCAL_IMAGE_API_URL="http://127.0.0.1:7861"
COMFYUI_CHECKPOINT="sd_xl_base_1.0.safetensors"
COMFYUI_WORKFLOW_PATH="ColoringBooks.json"
COMFYUI_DEBUG_PROMPTS="false"

# Verified emails promoted to admin at first authenticated request.
ADMIN_EMAILS="admin@example.test"
SUPPORT_EMAIL="support@example.com"

APP_URL="http://localhost:3000"
DAILY_GENERATION_LIMIT="20"
WORKER_POLL_MS="2000"

# Local verification and authenticated browser smoke tests only
TEST_ADMIN_EMAIL="admin@example.test"
TEST_ADMIN_PASSWORD="replace-with-a-local-test-password"
