# Coolify Docker Compose variables.
# Set these in Coolify's Environment Variables screen, then rebuild.

PORT=3000
NODE_ENV=production

# Browser-safe Supabase values. These are required at build time.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_GOOGLE_AUTH_ENABLED=true
VITE_LOCAL_AI_ENABLED=false

# Public site URL used for SEO tags (canonical, OG, sitemap, robots.txt). Required at build time.
VITE_SITE_URL=https://your-domain.example
# Self-hosted Plausible analytics. Leave both empty to disable analytics entirely.
VITE_PLAUSIBLE_DOMAIN=your-domain.example
VITE_PLAUSIBLE_SCRIPT_URL=https://analytics.your-domain.example/js/script.manual.js

# Backend-only Supabase values.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLIC_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Optional: direct Postgres connection string. When set, the one-shot `migrate` service applies
# pending SQL migrations on each deploy (tracked in schema_migrations). For a self-hosted Supabase
# on the same host, point it at the internal DB, e.g. postgresql://postgres:PASS@supabase-db:5432/postgres
SUPABASE_DB_URL=

# 32-byte key encoded as 64 hexadecimal characters.
AI_KEYS_MASTER_KEY=replace-with-openssl-rand-hex-32

# Optional, but recommended for platform moderation (Gemini API key).
GEMINI_MODERATION_API_KEY=
ALLOW_DEGRADED_MODERATION=false

# Keep local AI disabled on Coolify unless you also deploy a compatible image service.
LOCAL_AI_ENABLED=false
LOCAL_IMAGE_API_URL=http://127.0.0.1:7861
COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
COMFYUI_WORKFLOW_PATH=ColoringBooks.json
COMFYUI_DEBUG_PROMPTS=false

ADMIN_EMAILS=admin@example.com
SUPPORT_EMAIL=support@example.com
APP_URL=https://your-domain.example
DAILY_GENERATION_LIMIT=20
WORKER_POLL_MS=2000
