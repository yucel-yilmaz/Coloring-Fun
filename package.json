{
  "name": "coloring-fun",
  "private": true,
  "version": "0.1.0",
  "description": "Ebeveyn kontrollü, yapay zeka destekli boyama uygulamasi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yucel-yilmaz/Coloring-Fun.git"
  },
  "bugs": {
    "url": "https://github.com/yucel-yilmaz/Coloring-Fun/issues"
  },
  "homepage": "https://github.com/yucel-yilmaz/Coloring-Fun#readme",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "worker": "tsx server/worker.ts",
    "local-ai:setup": "bash local-ai/setup.sh",
    "local-ai:start": "bash local-ai/start.sh",
    "catalog:generate": "tsx scripts/generate-curated-catalog.ts",
    "seo:generate": "tsx scripts/generate-seo-files.ts",
    "cleanup": "tsx server/cleanup.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "svg:evaluate": "tsx scripts/svg-evaluate.ts",
    "verify:supabase": "tsx scripts/verify-local-supabase.ts",
    "supabase:start": "supabase start -x studio,imgproxy,edge-runtime,logflare,vector,supavisor,realtime",
    "supabase:status": "supabase status",
    "supabase:stop": "supabase stop",
    "build": "tsx scripts/generate-seo-files.ts && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild server/worker.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/worker.cjs && esbuild server/cleanup.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/cleanup.cjs && esbuild scripts/db-migrate.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/migrate.cjs",
    "start": "node dist/server.cjs",
    "start:worker": "node dist/worker.cjs",
    "start:migrate": "node dist/migrate.cjs",
    "start:cleanup": "node dist/cleanup.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@huggingface/inference": "^4.13.23",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.3.4",
    "jose": "^6.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mustache": "^4.2.0",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.1",
    "sharp": "^0.35.3",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "supabase": "^2.109.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
}
